{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "routes/**",
          "views/**",
          "public/**",
          "config/**",
          "validate/**",
          "middlewares/**",
          "helpers/**",
          "models/**",
          "controllers/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.js"
    }
  ]
}